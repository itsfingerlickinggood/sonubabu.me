{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/learnings", "destination": "/learnings.html" },
    { "source": "/learnings/", "destination": "/learnings.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/", "destination": "/blog.html" },
    { "source": "/projects", "destination": "/projects.html" },
    { "source": "/projects/", "destination": "/projects.html" },
    { "source": "/research", "destination": "/research.html" },
    { "source": "/research/", "destination": "/research.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/projects/:slug", "destination": "/projects/:slug.html" },
    { "source": "/research/:slug", "destination": "/research/:slug.html" }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=2592000"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=2592000"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/og-image.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
